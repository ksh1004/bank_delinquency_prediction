# ====================================================
# 07_bank_delinquency_prediction 프로젝트 API 키 설정
# ====================================================
# 이 파일을 복사해서 .env 파일로 만들고, 실제 키를 입력하세요.
# 예: copy .env.example .env (Windows)

# [1] 한국은행 ECOS API 키
# 발급: https://ecos.bok.or.kr → 회원가입 → 마이페이지 → OpenAPI 서비스 이용 신청
# 없으면 "sample" 키로 작동 (제한적 - 일부 데이터만 가능)
ECOS_API_KEY=sample

# [2] 공공데이터포털 API 키 (연체율 데이터 자동 수집에 필요)
# 발급: https://www.data.go.kr → 회원가입 → 로그인 → 마이페이지 → 인증키 발급
# 없으면 FISIS 수동 다운로드 방식으로 대체 가능
DATA_GO_KR_API_KEY=여기에_공공데이터포털_키_입력
